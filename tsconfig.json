{
  "include": [".vitepress/**/*.ts", "**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "target": "es2024",
    "module": "node20",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "./env.d.ts"]
  }
}
