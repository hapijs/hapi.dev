        "@octokit/rest": "^22.0.1",
        "@types/node": "^24.13.3",
        "@types/semver": "^7.7.1",
        "oxfmt": "^0.60.0",
        "oxlint": "^1.75.0",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
